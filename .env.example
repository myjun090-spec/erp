APP_BASE_URL=http://localhost:3140
ERP_AUTH_SECRET=replace-with-a-long-random-secret

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3140/auth/google/callback
GOOGLE_HOSTED_DOMAIN=
GOOGLE_DEFAULT_ROLE=executive

# 관리자/경영진만 env에서 고정하고, 일반 사용자는 users 컬렉션으로 매핑
GOOGLE_PLATFORM_ADMIN_EMAILS=
GOOGLE_DOMAIN_LEAD_EMAILS=
GOOGLE_EXECUTIVE_EMAILS=
# 테스트 또는 임시 체험 계정을 위한 미등록 Google 로그인 허용 여부
ERP_ENABLE_UNPROVISIONED_GOOGLE_LOGIN=false
ERP_UNPROVISIONED_GOOGLE_ROLE=executive
ERP_ENABLE_PREVIEW_LOGIN=false

# 법제처 Open API (법령 검색)
LAW_OC=

# 도로명주소 API (우편번호 검색) - juso.go.kr
JUSO_CONFIRM_KEY=

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/erp?retryWrites=true&w=majority
MONGODB_DB_NAME=erp
